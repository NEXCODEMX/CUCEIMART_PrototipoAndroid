<?xml version="1.0" encoding="utf-8"?>
<!-- Layout central de la aplicación basado en la arquitectura del README -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_overlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Campo de búsqueda con estilo tipo Amazon -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="2dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/buscador_principal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:iconifiedByDefault="false"
                app:queryBackground="@android:color/transparent"
                app:queryHint="Buscar productos o negocios..." />
        </androidx.cardview.widget.CardView>

        <!-- Sección: Emprendedor Destacado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*** EMPRENDEDOR DESTACADO ***"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.1" />

        <androidx.cardview.widget.CardView
            android:id="@+id/tarjeta_destacado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imagen_destacado"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    android:contentDescription="Emprendedor Destacado" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/texto_nombre_destacado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Negocio"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/texto_calificacion_destacado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★★★★★ (48 reseñas)"
                        android:textColor="#FFB300"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#xf054;"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:tag="fa_icon" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sección: Categorías en Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORÍAS"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <GridLayout
            android:id="@+id/cuadricula_categorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:alignmentMode="alignMargins"
            android:layout_marginBottom="24dp">

            <!-- Comida y Bebida -->
            <LinearLayout
                android:id="@+id/cat_comida"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:text="&#xf2e7;"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_icon"
                    android:tag="fa_icon" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comida"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Ropa y Accesorios -->
            <LinearLayout
                android:id="@+id/cat_ropa"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:text="&#xf553;"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_icon"
                    android:tag="fa_icon" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ropa"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Tecnología -->
            <LinearLayout
                android:id="@+id/cat_tech"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:text="&#xf109;"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_icon"
                    android:tag="fa_icon" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tech"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Servicios -->
            <LinearLayout
                android:id="@+id/cat_servicios"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:text="&#xf0ad;"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_icon"
                    android:tag="fa_icon" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Servicios"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </GridLayout>

        <!-- Sección: Emprendedores Recientes -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMPRENDEDORES RECIENTES"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_alignParentStart="true" />

            <TextView
                android:id="@+id/boton_ver_todos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver todos"
                android:textColor="@color/ocean_primary_start"
                android:textSize="12sp"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_emprendedor_simple" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
